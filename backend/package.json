{
  "name": "realcpa-hub-backend",
  "version": "1.0.0",
  "description": "Backend and API for FactPay",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts",
    "db:studio": "prisma studio",
    "restore-admin": "ts-node -P tsconfig.seed.json prisma/restore-admin.ts",
    "db:seed-supl": "ts-node -P tsconfig.seed.json prisma/seed-supl-categories.ts",
    "db:seed-locations": "ts-node -P tsconfig.seed.json prisma/seed-locations.ts",
    "start": "node dist/index.js",
    "dev": "ts-node --compiler-options {\"module\":\"CommonJS\"} src/index.ts"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.47.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.71.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^7.0.9",
    "@types/speakeasy": "^2.0.10",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
